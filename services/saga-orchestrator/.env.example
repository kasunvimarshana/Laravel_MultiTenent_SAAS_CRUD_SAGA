APP_NAME="SAGA Orchestrator"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=saga_orchestrator
DB_USERNAME=saga_user
DB_PASSWORD=saga_password

# -----------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=saga_exchange
RABBITMQ_PREFETCH_COUNT=1
RABBITMQ_CONSUMER_TIMEOUT=0

# -----------------------------------------------------------------------
# Queue names
# -----------------------------------------------------------------------
QUEUE_ORDER_COMMANDS=order_commands
QUEUE_INVENTORY_COMMANDS=inventory_commands
QUEUE_PAYMENT_COMMANDS=payment_commands
QUEUE_NOTIFICATION_COMMANDS=notification_commands
QUEUE_SAGA_EVENTS=saga_events

# -----------------------------------------------------------------------
# SAGA settings
# -----------------------------------------------------------------------
SAGA_TIMEOUT_CREATE_ORDER=30
SAGA_TIMEOUT_RESERVE_INVENTORY=30
SAGA_TIMEOUT_PROCESS_PAYMENT=60
SAGA_TIMEOUT_SEND_NOTIFICATION=15
SAGA_TIMEOUT_DEFAULT=30
SAGA_RETRY_MAX_ATTEMPTS=3
SAGA_RETRY_DELAY_SECONDS=5
SAGA_RETRY_BACKOFF_FACTOR=2.0

# -----------------------------------------------------------------------
# Downstream service URLs
# -----------------------------------------------------------------------
SERVICE_ORDER_URL=http://order-service:8001
SERVICE_INVENTORY_URL=http://inventory-service:8002
SERVICE_PAYMENT_URL=http://payment-service:8003
SERVICE_NOTIFICATION_URL=http://notification-service:8004

# -----------------------------------------------------------------------
# Cache / Session
# -----------------------------------------------------------------------
CACHE_DRIVER=redis
SESSION_DRIVER=redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
