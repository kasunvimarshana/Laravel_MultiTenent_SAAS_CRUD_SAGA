# Application
PORT=3003
NODE_ENV=development
LOG_LEVEL=info

# MongoDB (different tech stack from PHP services)
MONGODB_URI=mongodb://localhost:27017/payment_service

# RabbitMQ - SAGA communication
RABBITMQ_URL=amqp://guest:guest@localhost:5672
PAYMENT_COMMAND_QUEUE=payment.commands
PAYMENT_EVENT_EXCHANGE=saga.events
PAYMENT_DLQ=payment.commands.dlq
RABBITMQ_PREFETCH=10

# Payment simulation
PAYMENT_SUCCESS_RATE=0.9
PAYMENT_PROCESSING_DELAY_MS=100

# Auth
JWT_SECRET=change-me-in-production

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=*
